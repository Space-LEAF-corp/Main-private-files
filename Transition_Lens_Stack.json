// Transition Lens Controller — Photochromic primary, EC assist (TypeScript-like pseudocode)

type Mode = "idle" | "uv_detected" | "glare_high" | "max_protection";

interface UVReading {
  uva_mW_cm2: number;  // 320–400 nm
  uvb_mW_cm2: number;  // 280–320 nm
}

class TransitionLensController {
  mode: Mode = "idle";
  photochromicState = 0;   // 0..100% activation (model of dye darkening)
  ecDriveLevel = 0;        // 0..100% electrochromic assist
  lastUpdate = 0;

  constructor(
    private uvThreshold = 0.5,       // mW/cm2 combined UVA+UVB
    private glareLuxThreshold = 20000 // ambient lux
  ) {}

  // Called every 100–200 ms with sensor updates
  updateSensors(uv: UVReading, ambientLux: number, dt_ms: number) {
    const uvLevel = uv.uva_mW_cm2 + uv.uvb_mW_cm2;
    const uvHigh = uvLevel >= this.uvThreshold;
    const glareHigh = ambientLux >= this.glareLuxThreshold;

    if (uvHigh && glareHigh) {
      this.mode = "max_protection";
      this.photochromicState = this.approxPhotochromicRise(this.photochromicState, dt_ms);
      this.activateEC(80); // boost visible OD quickly
      this.showTriangles("max_protection");
    } else if (uvHigh) {
      this.mode = "uv_detected";
      this.photochromicState = this.approxPhotochromicRise(this.photochromicState, dt_ms);
      this.activateEC(20); // small assist to bridge rise time
      this.showTriangles("uv_detected");
    } else if (glareHigh) {
      this.mode = "glare_high";
      this.photochromicState = this.approxPhotochromicFade(this.photochromicState, dt_ms);
      this.activateEC(40); // fast glare control without UV
      this.showTriangles("glare_high");
    } else {
      this.mode = "idle";
      this.photochromicState = this.approxPhotochromicFade(this.photochromicState, dt_ms);
      this.activateEC(0);
      this.clearTriangles();
    }

    this.logEvent(uvLevel, ambientLux);
    this.lastUpdate = Date.now();
  }

  // Approximate photochromic kinetics: first-order rise/fade with time constants
  approxPhotochromicRise(statePercent: number, dt_ms: number): number {
    const tauRise_ms = 3000; // ~3 s rise
    const target = 100;
    const alpha = 1 - Math.exp(-dt_ms / tauRise_ms);
    return Math.min(100, statePercent + alpha * (target - statePercent));
  }

  approxPhotochromicFade(statePercent: number, dt_ms: number): number {
    const tauFade_ms = 60000; // ~60 s fade
    const target = 0;
    const alpha = 1 - Math.exp(-dt_ms / tauFade_ms);
    return Math.max(0, statePercent - alpha * (statePercent - target));
  }

  // Map EC level to hardware drive (voltage/current/PWM)
  activateEC(levelPercent: number) {
    this.ecDriveLevel = levelPercent;
    // sendECDrive(levelPercent); // hardware-specific
  }

  // Visual triangular feedback (does not block UV)
  showTriangles(mode: Mode) {
    switch (mode) {
      case "uv_detected":
        renderOverlay({ color: "blue", pattern: "solid" });
        break;
      case "glare_high":
        renderOverlay({ color: "green", pattern: "soft_wave" });
        break;
      case "max_protection":
        renderOverlay({ color: "purple", pattern: "ripple" });
        break;
      default:
        this.clearTriangles();
    }
  }

  clearTriangles() {
    renderOverlay({ color: "transparent", pattern: "none" });
  }

  logEvent(uvLevel: number, ambientLux: number) {
    ceremonialLog({
      timestamp: Date.now(),
      mode: this.mode,
      photochromicState: this.photochromicState,
      ecDriveLevel: this.ecDriveLevel,
      uvLevel_mW_cm2: uvLevel,
      ambientLux
    });
  }
}

// Placeholder hardware/UI hooks
function renderOverlay(opts: { color: string; pattern: string }) { /* device UI */ }
function ceremonialLog(entry: Record<string, unknown>) { /* encrypted on-device log */ }
