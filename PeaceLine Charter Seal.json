<script type="module">
  import sodium from 'https://cdn.skypack.dev/libsodium-wrappers';

  await sodium.ready;

  // Generate an X25519 key pair (crypto_box)
  export async function generateKeyPair() {
    const kp = sodium.crypto_box_keypair();
    return {
      publicKeyB64: sodium.to_base64(kp.publicKey, sodium.base64_variants.ORIGINAL),
      secretKeyB64: sodium.to_base64(kp.privateKey, sodium.base64_variants.ORIGINAL)
    };
  }

  // Create a sealed box for recipient public key (Base64 in, Base64 out)
  export function encryptForRecipient(recipientPublicKeyB64, plaintextUtf8) {
    const recipientPub = sodium.from_base64(recipientPublicKeyB64, sodium.base64_variants.ORIGINAL);
    const cipher = sodium.crypto_box_seal(sodium.from_string(plaintextUtf8), recipientPub);
    return sodium.to_base64(cipher, sodium.base64_variants.ORIGINAL);
  }

  // Open sealed box using recipient secret key and public key (both Base64)
  export function decryptSealedBox(cipherB64, publicKeyB64, secretKeyB64) {
    const cipher = sodium.from_base64(cipherB64, sodium.base64_variants.ORIGINAL);
    const pub = sodium.from_base64(publicKeyB64, sodium.base64_variants.ORIGINAL);
    const sec = sodium.from_base64(secretKeyB64, sodium.base64_variants.ORIGINAL);
    const msg = sodium.crypto_box_seal_open(cipher, pub, sec);
    return sodium.to_string(msg);
  }
</script>
