// server.js
// Minimal PeaceLine relay: invitation registration, public key registry, encrypted message relay.
// Plaintext never touches disk. Use HTTPS and a reverse proxy. Audit before production.

import express from 'express';
import helmet from 'helmet';
import rateLimit from 'express-rate-limit';
import { randomBytes } from 'crypto';
import { readFileSync } from 'fs';
import sodium from 'libsodium-wrappers';

const app = express();
app.use(express.json({ limit: '32kb' }));
app.use(helmet({
  contentSecurityPolicy: false // serve static separately; tighten CSP in production
}));
app.use(rateLimit({ windowMs: 60_000, max: 60 }));

// In-memory registries (replace with encrypted store if needed)
const invitations = new Map(); // token -> { scope, expiresAt }
const registry = new Map();     // keyId -> { pubkey (Uint8Array), createdAt }
const mailbox = new Map();      // keyId -> [ { fromId, ciphertext, createdAt } ]

// Load governance seal for reference (optional)
let seal;
try {
  seal = JSON.parse(readFileSync('./governance_seal.json', 'utf8'));
} catch (e) {
  seal = { artifact: 'PeaceLine Charter Seal', version: '1.0.0' };
}

await sodium.ready;

// Utility: base64 helpers
const b64uToBytes = (s) => sodium.from_base64(s, sodium.base64_variants.ORIGINAL);
const bytesToB64u = (b) => sodium.to_base64(b, sodium.base64_variants.ORIGINAL);

// Create an invitation (admin-only; wire behind auth)
app.post('/api/admin/invite', (req, res) => {
  const { scope = 'dialogue', ttlMinutes = 1440 } = req.body || {};
  const token = bytesToB64u(randomBytes(16));
  const expiresAt = Date.now() + ttlMinutes * 60_000;
  invitations.set(token, { scope, expiresAt });
  res.json({ token, scope, expiresAt });
});

// Acknowledge readiness: register a public key using an invitation token
app.post('/api/acknowledge', (req, res) => {
  const { pubkey, token } = req.body || {};
  if (!pubkey || !token) return res.status(400).json({ error: 'Missing pubkey or token' });

  const invite = invitations.get(token);
  if (!invite || invite.expiresAt < Date.now()) return res.status(403).json({ error: 'Invalid or expired token' });

  const pub = b64uToBytes(pubkey);
  if (pub.length !== sodium.crypto_box_PUBLICKEYBYTES) {
    return res.status(400).json({ error: 'Invalid public key length' });
  }
  const keyId = bytesToB64u(sodium.crypto_generichash(16, pub));
  registry.set(keyId, { pubkey: pub, createdAt: Date.now() });
  invitations.delete(token); // one-time use

  res.json({ message: 'Acknowledged. Key registered.', keyId });
});

// Send encrypted message: sealed box to recipient’s public key
app.post('/api/send', (req, res) => {
  const { fromId, toId, ciphertext } = req.body || {};
  if (!fromId || !toId || !ciphertext) return res.status(400).json({ error: 'Missing fields' });

  // We only accept sealed boxes. Server does not decrypt.
  const recipient = registry.get(toId);
  const sender = registry.get(fromId);
  if (!recipient || !sender) return res.status(404).json({ error: 'Unknown participant' });

  const bucket = mailbox.get(toId) || [];
  bucket.push({ fromId, ciphertext, createdAt: Date.now() });
  mailbox.set(toId, bucket);

  res.json({ message: 'Delivered to mailbox.' });
});

// Fetch messages (recipient polls)
app.post('/api/fetch', (req, res) => {
  const { keyId } = req.body || {};
  const participant = registry.get(keyId);
  if (!participant) return res.status(404).json({ error: 'Unknown participant' });

  const bucket = mailbox.get(keyId) || [];
  // Ephemeral by default: delete after fetch
  mailbox.set(keyId, []);
  res.json({ messages: bucket });
});

// Health (exposes no sensitive data)
app.get('/api/health', (_req, res) => {
  res.json({ status: 'ok', seal: { artifact: seal.artifact, version: seal.version } });
});

const PORT = process.env.PORT || 8787;
app.listen(PORT, () => {
  console.log(`PeaceLine relay listening on ${PORT}`);
});
