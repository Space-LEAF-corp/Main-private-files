      },
      "required": ["tone", "pacing", "formality", "symbolism"]
    },
    "triggers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "active": { "type": "boolean" }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
