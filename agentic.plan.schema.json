// Integrity demo: beacon + anomaly + owner confirmation
const beacon: IntegrityBeacon = {
  deviceId: "device_abc",
  time: new Date().toISOString(),
  attestationToken: "attest_xyz",
  healthFlags: ["ok"],
  networkSig: "wifi_home"
};

ledger.append({
  id: "evt_beacon_received",
