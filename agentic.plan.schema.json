{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "integrity.anomaly.schema.json",
  "title": "Anomaly",
  "type": "object",
  "required": ["type", "severity", "signals", "firstSeen"],
  "properties": {
    "type": { "type": "string", "enum": ["sim_swap", "failed_unlock", "geofence_violation", "tamper"] },
    "severity": { "type": "string", "enum": ["low", "medium", "high"] },
    "signals": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "firstSeen": { "type": "string", "format": "date-time" },
    "lastSeen": { "type": "string", "format": "date-time" }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "integrity.case.schema.json",
  "title": "EscalationCase",
  "type": "object",
  "required": ["caseId", "status", "ownerConfirmed"],
  "properties": {
    "caseId": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "Healthy",
        "AnomalyDetected",
        "Monitoring",
        "OwnerReview",
        "ConfirmedStolen",
        "ReportGenerated",
        "Escalated",
        "Resolved"
      ]
    },
    "ownerConfirmed": { "type": "boolean" },
    "reportArtifact": { "type": "string" },
    "authoritySubmittedAt": { "type": "string", "format": "date-time" }
  }
}
export interface IntegrityBeacon {
  deviceId: string;
  time: string;
  attestationToken: string;
  healthFlags?: string[];
  locationHint?: string;
  networkSig?: string;
}

export type AnomalyType = "sim_swap" | "failed_unlock" | "geofence_violation" | "tamper";

export interface Anomaly {
  type: AnomalyType;
  severity: "low" | "medium" | "high";
  signals: string[];
  firstSeen: string;
  lastSeen?: string;
}

export type CaseStatus =
  | "Healthy"
  | "AnomalyDetected"
  | "Monitoring"
  | "OwnerReview"
  | "ConfirmedStolen"
  | "ReportGenerated"
  | "Escalated"
  | "Resolved";

export interface EscalationCase {
  caseId: string;
  status: CaseStatus;
  ownerConfirmed: boolean;
  reportArtifact?: string; // signed JSON string or URI
  authoritySubmittedAt?: string;
}
import crypto from "crypto";

export interface Hashable {
  id: string;
  timestamp: string;
  payload: Record<string, unknown>;
}

export interface LedgerEntry {
  id: string;
  timestamp: string;
  payload: Record<string, unknown>;
  prevHash: string;
  hash: string;
  signature?: string;
}

export class AuditLedger {
  private chain: LedgerEntry[] = [];

  // Simple deterministic stringifier
  private stableStringify(obj: unknown): string {
    return JSON.stringify(obj, Object.keys(obj as object).sort());
  }

  private computeHash(entry: Omit<LedgerEntry, "hash">): string {
    const data = `${entry.id}|${entry.timestamp}|${this.stableStringify(entry.payload)}|${entry.prevHash}`;
    return crypto.createHash("sha256").update(data).digest("hex");
  }

  append(event: Hashable, sign?: (data: string) => string): LedgerEntry {
    const prevHash = this.chain.length ? this.chain[this.chain.length - 1].hash : "GENESIS";
    const partial: Omit<LedgerEntry, "hash"> = {
      id: event.id,
      timestamp: event.timestamp,
      payload: event.payload,
      prevHash
    };
    const hash = this.computeHash(partial);
    const signature = sign ? sign(hash) : undefined;
    const entry: LedgerEntry = { ...partial, hash, signature };
    this.chain.push(entry);
    return entry;
  }

  verify(): boolean {
    let prev = "GENESIS";
    for (const e of this.chain) {
      const expected = this.computeHash({ id: e.id, timestamp: e.timestamp, payload: e.payload, prevHash: prev });
      if (expected !== e.hash) return false;
      prev = e.hash;
    }
    return true;
  }

  getChain(): LedgerEntry[] {
    return [...this.chain];
  }
}
// Agentic demo: "Plan my week"
const ledger = new AuditLedger();

const plan: Plan = {
  id: "plan_001",
  title: "Weekly planning",
  goal: "Focus blocks + workouts + groceries",
  steps: [
    { id: "s1", description: "Read calendar", toolId: "calendar.read", params: {}, reversible: false },
    { id: "s2", description: "Propose focus blocks", toolId: "planner.propose", params: { blocks: 3 }, reversible: true },
    { id: "s3", description: "Create events", toolId: "calendar.write", params: { items: [] }, reversible: true }
  ],
  requiredScopes: ["calendar.read", "calendar.write"],
  riskLevel: "medium",
  approvalsRequired: 1,
  state: "PendingApproval"
};

ledger.append({
  id: "evt_plan_created",
  timestamp: new Date().toISOString(),
  payload: { type: "PlanCreated", planId: plan.id, state: plan.state }
});

plan.state = "Approved";
ledger.append({
  id: "evt_plan_approved",
  timestamp: new Date().toISOString(),
  payload: { type: "ApprovalGranted", planId: plan.id }
});

// Simulate step execution
plan.steps[0].status = "Executed";
ledger.append({
  id: "evt_step1_executed",
  timestamp: new Date().toISOString(),
  payload: { type: "StepExecuted", planId: plan.id, stepId: "s1" }
});

// …continue for other steps, previews, rollbacks as needed
