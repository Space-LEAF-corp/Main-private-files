{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic.plan.schema.json",
  "title": "Plan",
  "type": "object",
  "required": ["id", "title", "goal", "steps", "requiredScopes", "riskLevel", "state"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "goal": { "type": "string" },
    "constraints": { "type": "object", "additionalProperties": true },
    "steps": {
      "type": "array",
      "items": { "$ref": "agentic.step.schema.json" },
      "minItems": 1
    },
    "requiredScopes": { "type": "array", "items": { "type": "string" } },
    "riskLevel": { "type": "string", "enum": ["low", "medium", "high"] },
    "approvalsRequired": { "type": "integer", "minimum": 0 },
    "state": {
      "type": "string",
      "enum": [
        "Draft",
        "PendingApproval",
        "Approved",
        "Executing",
        "Paused",
        "Completed",
        "RolledBack",
        "Aborted"
      ]
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic.step.schema.json",
  "title": "Step",
  "type": "object",
  "required": ["id", "description", "toolId", "params", "reversible"],
  "properties": {
    "id": { "type": "string" },
    "description": { "type": "string" },
    "toolId": { "type": "string" },
    "scope": { "type": "string" },
    "params": { "type": "object", "additionalProperties": true },
    "previewDiff": { "type": "string" },
    "reversible": { "type": "boolean" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["Planned", "Previewed", "Approved", "Executed", "Failed", "RolledBack"] }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic.audit.schema.json",
  "title": "AuditEvent",
  "type": "object",
  "required": ["id", "timestamp", "actor", "action", "objectRef", "hash", "prevHash"],
  "properties": {
    "id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "actor": { "type": "string" },
    "action": { "type": "string" },
    "objectRef": { "type": "string" },
    "diff": { "type": "string" },
    "signature": { "type": "string" },
    "hash": { "type": "string" },
    "prevHash": { "type": "string" }
  }
}
// Agentic subsystem interfaces

export type PlanState =
  | "Draft"
  | "PendingApproval"
  | "Approved"
  | "Executing"
  | "Paused"
  | "Completed"
  | "RolledBack"
  | "Aborted";

export type StepStatus =
  | "Planned"
  | "Previewed"
  | "Approved"
  | "Executed"
  | "Failed"
  | "RolledBack";

export interface Step {
  id: string;
  description: string;
  toolId: string;
  scope?: string;
  params: Record<string, unknown>;
  previewDiff?: string;
  reversible: boolean;
  dependencies?: string[];
  status?: StepStatus;
}

export interface Plan {
  id: string;
  title: string;
  goal: string;
  constraints?: Record<string, unknown>;
  steps: Step[];
  requiredScopes: string[];
  riskLevel: "low" | "medium" | "high";
  approvalsRequired: number;
  state: PlanState;
  createdAt?: string;
  updatedAt?: string;
}

export interface ToolInvocation {
  toolId: string;
  scope: string;
  params: Record<string, unknown>;
  result?: unknown;
  errors?: string[];
  durationMs?: number;
}

export interface AuditEvent {
  id: string;
  timestamp: string;
  actor: string; // e.g., "User:LEIF" | "Agent:System"
  action: string; // e.g., "StepExecuted"
  objectRef: string; // e.g., "Plan:123/Step:2"
  diff?: string; // human-readable summary
  signature?: string; // detached signature over (id,timestamp,action,objectRef,diff,prevHash)
  hash: string;
  prevHash: string;
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "resonance.memory.schema.json",
  "title": "MemoryItem",
  "type": "object",
